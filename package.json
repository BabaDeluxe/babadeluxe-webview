{
  "name": "@babadeluxe/webview",
  "description": "Enterprise-grade AI Coding Assistant Interface by BabaDeluxe",
  "version": "0.1.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./constants/*": {
      "types": "./dist/constants/*.d.ts",
      "import": "./dist/constants/*.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/types/*.js"
    },
    "./validators/*": {
      "types": "./dist/validators/*.d.ts",
      "import": "./dist/validators/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "constants/*": [
        "./dist/constants/*.d.ts"
      ],
      "types/*": [
        "./dist/types/*.d.ts"
      ],
      "validators/*": [
        "./dist/validators/*.d.ts"
      ]
    }
  },
  "scripts": {
    "format": "eslint --fix . && prettier --write .",
    "dev": "vite",
    "dev-performance": "vite --profile --open",
    "preview": "vite preview",
    "build": "run-p type-check \"build-only {@}\" --",
    "test": "npm run test-unit && npm run test-e2e",
    "test-unit": "vitest run",
    "test-unit-watch": "vitest watch",
    "test-e2e": "playwright test",
    "test-e2e-ui": "playwright test --ui",
    "kill": "fkill -f :5100",
    "publish-patch": "npm run build && npm version patch && npm publish",
    "publish-minor": "npm run build && npm version minor && npm publish",
    "publish-major": "npm run build && npm version major && npm publish",
    "prepare": "husky",
    "type-check": "vue-tsc --build",
    "build-only": "vite build",
    "find-dead-code": "knip"
  },
  "dependencies": {
    "@babadeluxe/shared": "^0.20.6",
    "@iconify/types": "^2.0.0",
    "@lottiefiles/dotlottie-vue": "^0.10.1",
    "@statsig/js-client": "^1.7.0",
    "@stylistic/eslint-plugin": "5.0.0",
    "@supabase/supabase-js": "^2.57.0",
    "@typescript-eslint/parser": "8.58.1",
    "@vueuse/core": "^13.7.0",
    "colorino": "^0.19.3",
    "culori": "^4.0.2",
    "dexie": "^4.2.0",
    "dompurify": "^3.3.1",
    "eslint": "9.39.3",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.30",
    "markdown-it-code-copy": "^0.2.3",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-highlightjs": "^4.3.0",
    "markdown-it-katex": "^2.0.3",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.12.2",
    "neverthrow": "^8.2.0",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.4.1",
    "vue": "^3.5.18",
    "vue-eslint-parser": "10.0.0",
    "vue-markdown-render": "^2.2.1",
    "vue-router": "^4.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@iconify-json/ant-design": "^1.2.5",
    "@iconify-json/bi": "^1.2.7",
    "@iconify-json/fluent": "^1.2.39",
    "@iconify-json/hugeicons": "^1.2.23",
    "@iconify-json/ri": "^1.2.10",
    "@iconify-json/simple-icons": "^1.2.71",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@iconify-json/weui": "^1.2.4",
    "@playwright/test": "^1.57.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/culori": "^4.0.1",
    "@types/jsdom": "^21.1.7",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.16.5",
    "@unocss/preset-icons": "^66.4.2",
    "@unocss/transformer-directives": "^66.4.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/eslint-plugin": "^1.3.16",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "dotenv": "^17.2.3",
    "eslint-plugin-vue": "^10.8.0",
    "fkill-cli": "^8.0.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "knip": "^5.65.0",
    "npm-run-all": "^4.1.5",
    "rollup-plugin-visualizer": "^6.0.3",
    "typescript": "~5.8.0",
    "unocss": "^66.5.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.0.4",
    "xo": "^1.2.2"
  },
  "publishConfig": {
    "registry": "https://npflared.simonwaiblinger.workers.dev"
  }
}
