{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": false,
    "esModuleInterop": true,
    "composite": false,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",
    "skipLibCheck": true,
    "incremental": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "types": [
      "vite/client",
      "node",
      "jsdom"
    ],
  },
  "include": [
    "./src/**/*",
    "./tests/**/*",
    "./playwright.config.ts",
    "./vitest.config.ts"
  ],
}