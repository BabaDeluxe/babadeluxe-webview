{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "esModuleInterop": true,
    "composite": false,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",
    "incremental": true
  },
  "include": [
    "./src/**/*",
    "./tests/**/*",
    "./playwright.config.ts",
    "./vitest.config.ts",
    "./env.d.ts",
    "./vitest.shims.d.ts"
  ],
}